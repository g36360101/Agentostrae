# Web: exposed to the browser; do not put secrets here.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Reserved for a future real AI provider. Phase 0 uses deterministic mocks.
AI_PROVIDER=mock
AI_API_KEY=EXAMPLE_API_KEY
