# Database
DATABASE_URL="postgresql://agentos:agentos@localhost:5433/agentos?schema=public"

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
AUTH_MODE=session
DEMO_ACTOR_ID=00000000-0000-4000-8000-000000000000
